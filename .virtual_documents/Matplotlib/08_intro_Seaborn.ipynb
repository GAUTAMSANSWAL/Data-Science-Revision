import seaborn as sns
import matplotlib.pyplot as plt
import numpy as np


sns.set_theme(style="darkgrid")  # Options: whitegrid, dark, white, ticks


import numpy as np

x = np.array([0, 2, 3, 4, 5, 6, 7, 8, 9 ,10, 60])
y = np.sin(x)

sns.lineplot(x=x, y=y)
plt.title('Beautiful Line Plot')


print(sns.get_dataset_names())


tips = sns.load_dataset('tips')


tips


sns.lineplot(x='total_bill', y='tip', data=tips)


sns.scatterplot(x='total_bill', y='tip', data=tips)


sns.barplot(x='total_bill', y='tip', data=tips)


sns.boxplot(x='total_bill', y='tip', data=tips)


flights = sns.load_dataset('flights')


flights


pv = flights.pivot(index = "month", columns = "year", values = "passengers" )


pv


sns.heatmap(pv, annot = True, fmt = 'd', cmap = 'YlGnBu')



